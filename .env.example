# Copy to .env for custom (non-Docker) setups. Inside Docker Compose these
# values are provided automatically by docker-compose.yml.

# Execution mode: dev | demo | production
# - dev: Nuxt DevTools on, demo seed data on container start
# - demo: DevTools off, demo seed data on container start
# - production: DevTools off, no automatic demo seed (migrations only)
NUXT_PUBLIC_APP_MODE=dev

# Local HTTP port: host port mapped to the dev app container (default 3000).
# For custom Nuxt setups without Docker, set PORT or NITRO_PORT instead.
APP_PORT=3000

# Optional: comma-separated hostnames for the Vite dev server (reverse proxy / tunnel).
# Example: freiwerk.example.org,www.freiwerk.example.org
# NUXT_DEV_ALLOWED_HOSTS=

# PostgreSQL connection string
DATABASE_URL="postgresql://freiwerk:freiwerk@localhost:5432/freiwerk"

# Secret used to seal session cookies (use a long random string, >= 32 chars)
NUXT_SESSION_PASSWORD="replace-with-a-long-random-secret-at-least-32-chars"

# Add the `Secure` attribute to the session cookie. Only set this to "true" when
# the app is served over HTTPS. Over plain HTTP (typical for local/demo), Secure
# cookies are rejected by browsers on remote hosts and silently break login —
# so the default is "false". Set to "true" for real HTTPS deployments.
NUXT_SESSION_COOKIE_SECURE="false"

# ---------------------------------------------------------------------------
# Passwordless login (magic-link) email — SMTP configuration
# ---------------------------------------------------------------------------
# If NUXT_SMTP_HOST is left empty, FreiWerk does NOT send real emails and logs
# the magic link to the server console instead — convenient for local/demo use.
# To send real emails, fill in your SMTP provider's credentials below.
NUXT_SMTP_HOST=""
NUXT_SMTP_PORT="587"
# "true" for implicit TLS (port 465); leave empty to use STARTTLS on 587.
NUXT_SMTP_SECURE=""
NUXT_SMTP_USER=""
NUXT_SMTP_PASS=""
# Sender shown to recipients, e.g. "FreiWerk <no-reply@your-domain.org>"
NUXT_SMTP_FROM="FreiWerk <no-reply@freiwerk.local>"

# AI provider keys (optional, not used in MVP)
OLLAMA_URL=""
OLLAMA_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
CLAUDE_API_KEY=""
